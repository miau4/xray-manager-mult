],

"outbounds": [
{
"protocol": "freedom",
"tag": "direct"
},
{
"protocol": "blackhole",
"tag": "blocked"
}
],

"policy": {
"levels": {
"0": {
"statsUserDownlink": true,
"statsUserUplink": true,
"statsUserOnline": true
}
},
"system": {
"statsInboundDownlink": true,
"statsInboundUplink": true
}
},

"routing": {
"domainStrategy": "AsIs",
"rules": [
{
"type": "field",
"inboundTag": ["api"],
"outboundTag": "api"
},
{
"type": "field",
"ip": ["geoip:private"],
"outboundTag": "blocked"
},
{
"type": "field",
"protocol": ["bittorrent"],
"outboundTag": "blocked"
}
]
},

"stats": {}
}
